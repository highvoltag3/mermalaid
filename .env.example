VITE_APP_NAME=Mermalaid
VITE_APP_VERSION=
VITE_GITHUB_REPO=
VITE_PUBLIC_SHARE_BASE_URL=
VITE_ENABLE_AI_FIXER=true
VITE_OPENAI_API_KEY=

# ── Mermalaid for Slack (server-side; NOT exposed to the browser) ───────────
# Set the same values in your Vercel project (Settings → Environment Variables).
# See slack/README.md for the full setup guide.

# Bot User OAuth Token from your Slack app (Install App). Starts with xoxb-
SLACK_BOT_TOKEN=
# Signing Secret (Basic Information → App Credentials)
SLACK_SIGNING_SECRET=

# Optional — local dev only: path to a Chrome/Chromium binary for the renderer.
# Defaults to the standard macOS Google Chrome location if unset.
# PUPPETEER_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# Optional — fallback URL for the Mermaid library if the bundled copy isn't
# found at runtime. Only library JS is fetched, never diagram content.
# MERMAID_UMD_URL=https://cdn.jsdelivr.net/npm/mermaid@11.15.0/dist/mermaid.min.js

# ── Public preview links (/api/og, /api/preview) ───────────────────────────
# Set a random secret (e.g. `openssl rand -hex 32`) to sign preview links so the
# /api/og render endpoint only accepts links this server issued (blocks
# hotlinking / embedding it as a free render API). If unset, preview links work
# unsigned and /api/og will render any diagram passed to it.
# PREVIEW_LINK_SECRET=
